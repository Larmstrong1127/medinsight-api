APP_ENVIRONMENT=development
DEBUG=true

# API Security — comma-separated list of valid API keys
API_KEYS=dev-key-change-me-in-production

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Storage backend: "local" for dev, "aws" for production
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data

# AWS (only needed when STORAGE_BACKEND=aws)
AWS_REGION=us-east-1
S3_BUCKET=medinsight-documents-prod
DYNAMODB_TABLE=medinsight-documents
AUDIT_TABLE=medinsight-audit-logs
